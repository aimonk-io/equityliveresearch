# ============================================================================
# equityliveresearch (Marketing Site) — environment variables
#
# Copy to .env.local for local development:  cp .env.example .env.local
# .env.local is git-ignored. NEVER commit real values or secrets.
# Staging/production values live in the deployment platform's secret store.
#
# Naming:
#   UPPER_SNAKE_CASE          server-only (secrets belong here)
#   NEXT_PUBLIC_*             compiled into the browser bundle — never secret
#
# Every variable is validated in src/env.ts (zod). Adding one? Update env.ts too.
# ============================================================================

# Deployment environment this instance runs as.
APP_ENV=development

# Canonical site URL — used for metadataBase, sitemap, robots, and OpenGraph.
NEXT_PUBLIC_SITE_URL=http://localhost:3002
